# Path to your Obsidian vault on the host (required)
# PKM_VAULT_PATH=/mnt/c/Users/you/Documents/MyVault
PKM_VAULT_PATH=

# Writable folder inside the vault (default: claude-workspace)
# Claude can read the entire vault but only write to this folder.
# The folder is created automatically if it doesn't exist.
# PKM_WRITE_DIR=claude-workspace

# Optional: remap ttyd port (default 7681)
# TTYD_PORT=7681
