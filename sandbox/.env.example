# IMPORTANT: Start the container from the Obsidian plugin unless this
# file is fully configured. The plugin passes these as environment
# variables automatically. Running 'docker compose up -d' without
# setting at least PKM_VAULT_PATH will result in missing vault mounts.

# Path to your Obsidian vault on the host
# PKM_VAULT_PATH=/mnt/c/Users/you/Documents/MyVault

# Writable folder inside the vault (default: agent-workspace)
# PKM_WRITE_DIR=agent-workspace

# ttyd port (default: 7681)
# TTYD_PORT=7681

# Bind address for ttyd (default: 127.0.0.1, set 0.0.0.0 for network access)
# TTYD_BIND=127.0.0.1

# Memory MCP file name, stored inside the vault write directory (default: memory.json)
# MEMORY_FILE_NAME=memory.json

# Allowed private network hosts for firewall (comma-separated IPs/CIDRs)
# Example: NAS, local API server
# ALLOWED_PRIVATE_HOSTS=192.168.1.100,10.0.0.5

# Container resource limits
# CONTAINER_MEMORY=8G
# CONTAINER_CPUS=4
